<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} %-5level %logger - %msg%n%ex{full}</pattern>
    </encoder>
  </appender>

  <logger name="rs117.hd.renderer.zone.SceneManager" level="INFO" />
  <logger name="org.tides.TidesPlugin" level="INFO" />

  <root level="DEBUG">
    <appender-ref ref="STDOUT" />
  </root>
</configuration>
